 	return 0;
 }
 
+/* ---------- Added for FM25G02B (Based on Datasheet Table 6) ---------- */
+/* Status Register (C0h) : Bit6=ECCS2, Bit5=ECCS1, Bit4=ECCS0 */
+#define STATUS_FMSH_ECC_MASK		(7 << 4)  /* 0111 0000 */
+#define STATUS_FMSH_ECC_NONE		(0 << 4)  /* 000: No error */
+#define STATUS_FMSH_ECC_1BIT		(1 << 4)  /* 001: 1 bit corrected */
+#define STATUS_FMSH_ECC_2BIT		(2 << 4)  /* 010: 2 bits corrected */
+#define STATUS_FMSH_ECC_3BIT		(3 << 4)  /* 011: 3 bits corrected */
+#define STATUS_FMSH_ECC_4BIT		(4 << 4)  /* 100: 4 bits corrected */
+#define STATUS_FMSH_ECC_5BIT		(5 << 4)  /* 101: 5 bits corrected */
+#define STATUS_FMSH_ECC_6BIT		(6 << 4)  /* 110: 6 bits corrected */
+#define STATUS_FMSH_ECC_7BIT		(7 << 4)  /* 111: 7 bits corrected (max) */
+#define STATUS_FMSH_ECC_UNCORRECTABLE	(7 << 4)  /* Same as 7BIT, but indicates uncorrectable */
+
+static int fm25g02b_ooblayout_ecc(struct mtd_info *mtd, int section,
+				  struct mtd_oob_region *region)
+{
+	if (section >= 8)
+		return -ERANGE;
+	region->offset = 64 + section * 8;
+	region->length = 8;
+	return 0;
+}
+
+static int fm25g02b_ooblayout_free(struct mtd_info *mtd, int section,
+				   struct mtd_oob_region *region)
+{
+	if (section)
+		return -ERANGE;
+	region->offset = 2;
+	region->length = 62;
+	return 0;
+}
+
+static const struct mtd_ooblayout_ops fm25g02b_ooblayout = {
+	.ecc = fm25g02b_ooblayout_ecc,
+	.free = fm25g02b_ooblayout_free,
+};
+
+static int fm25g02b_ecc_get_status(struct spinand_device *spinand, u8 status)
+{
+	u8 ecc_bits = (status & STATUS_FMSH_ECC_MASK) >> 4;
+
+	switch (ecc_bits) {
+	case 0x00:  /* 000 - No bit errors */
+		return 0;
+	case 0x01:  /* 001 - 1 bit corrected */
+		return 1;
+	case 0x02:  /* 010 - 2 bits corrected */
+		return 2;
+	case 0x03:  /* 011 - 3 bits corrected */
+		return 3;
+	case 0x04:  /* 100 - 4 bits corrected */
+		return 4;
+	case 0x05:  /* 101 - 5 bits corrected */
+		return 5;
+	case 0x06:  /* 110 - 6 bits corrected */
+		return 6;
+	case 0x07:  /* 111 - Uncorrectable ECC error */
+		return -EBADMSG;
+	default:
+		break;
+	}
+	return -EINVAL;
+}
+/* -------------------------------------------------------- */
+
 static const struct mtd_ooblayout_ops fm25s01a_ooblayout = {
 	.ecc = fm25s01a_ooblayout_ecc,
 	.free = fm25s01a_ooblayout_free,
@@ -132,6 +175,19 @@ static const struct spinand_info fmsh_sp
 		     SPINAND_HAS_QE_BIT,
 		     SPINAND_ECCINFO(&fm25s01bi3_ooblayout,
 				      fm25s01bi3_ecc_get_status)),
