--- a/drivers/mtd/nand/spi/fmsh.c
+++ b/drivers/mtd/nand/spi/fmsh.c
@@ -102,6 +102,23 @@ static int fm25s01bi3_ooblayout_free(str
 	return 0;
 }
 
+/* ---------- Added for FM25G02B (Fixed Version) ---------- */
+#define STATUS_FMSH_ECC_MASK		(3 << 4)
+#define STATUS_FMSH_ECC_NONE		(0 << 4)
+#define STATUS_FMSH_ECC_CORRECTED	(1 << 4)
+#define STATUS_FMSH_ECC_MAX_CORRECTED	(2 << 4)
+#define STATUS_FMSH_ECC_UNCORRECTABLE	(3 << 4)
+
+static int fm25g02b_ecc_get_status(struct spinand_device *spinand, u8 status)
+{
+	switch (status & STATUS_FMSH_ECC_MASK) {
+	case STATUS_FMSH_ECC_NONE: return 0;
+	case STATUS_FMSH_ECC_CORRECTED: return 1;
+	case STATUS_FMSH_ECC_MAX_CORRECTED: return 8;
+	case STATUS_FMSH_ECC_UNCORRECTABLE: return -EBADMSG;
+	default: break;
+	}
+	return -EINVAL;
+}
+/* -------------------------------------------------------- */
+
 static const struct mtd_ooblayout_ops fm25s01a_ooblayout = {
 	.ecc = fm25s01a_ooblayout_ecc,
 	.free = fm25s01a_ooblayout_free,
@@ -132,6 +149,16 @@ static const struct spinand_info fmsh_sp
 		     SPINAND_HAS_QE_BIT,
 		     SPINAND_ECCINFO(&fm25s01bi3_ooblayout,
 				      fm25s01bi3_ecc_get_status)),
+	/* FM25G02B - Optimized for OpenWrt 6.12 & UBI */
+	SPINAND_INFO("FM25G02B",
+		     SPINAND_ID(SPINAND_READID_METHOD_OPCODE_DUMMY, 0xD2),
+		     NAND_MEMORG(1, 2048, 128, 64, 2048, 40, 1, 1, 1),
+		     NAND_ECCREQ(8, 512),
+		     SPINAND_INFO_OP_VARIANTS(&read_cache_variants,
+					      &write_cache_variants,
+					      &update_cache_variants),
+		     SPINAND_HAS_QE_BIT,
+		     SPINAND_ECCINFO(NULL, fm25g02b_ecc_get_status)),
 };
 
 static const struct spinand_manufacturer_ops fmsh_spinand_manuf_ops = {
@@ -144,3 +193,4 @@ const struct spinand_manufacturer fmsh_s
 	.nchips = ARRAY_SIZE(fmsh_spinand_table),
 	.ops = &fmsh_spinand_manuf_ops,
 };
